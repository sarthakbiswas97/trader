# =============================================================================
# AUTONOMOUS TRADING AGENT - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# -----------------------------------------------------------------------------
# Zerodha Kite Connect Credentials
# Get from: https://developers.kite.trade/apps
# -----------------------------------------------------------------------------
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# -----------------------------------------------------------------------------
# Trading Mode
# -----------------------------------------------------------------------------
# "paper" = Simulated trading with real market data (safe for testing)
# "live"  = Real money trading (use with caution!)
TRADING_MODE=paper

# Paper trading initial capital (only used in paper mode)
PAPER_TRADING_CAPITAL=100000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/trader

# -----------------------------------------------------------------------------
# Redis (for caching and pub/sub)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=true

# -----------------------------------------------------------------------------
# Risk Management (override defaults)
# -----------------------------------------------------------------------------
# MAX_POSITION_PCT=0.05
# MAX_TOTAL_EXPOSURE=0.20
# MAX_DAILY_LOSS_PCT=0.03
# MAX_DRAWDOWN_PCT=0.10
# MAX_TRADES_PER_DAY=20
